# ─────────────────────────────────────────────────────────────
# RankUpPH — Environment Variables
# Copy to `.env` and fill in. The app runs locally even if the
# optional integrations (Stripe/Pusher/Cloudinary/Google) are blank —
# those features degrade gracefully when keys are absent.
# ─────────────────────────────────────────────────────────────

# ── Core (required) ──────────────────────────────────────────
# Supabase / Postgres. Use the pooled connection string for the app
# and the direct connection for migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rankupph?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/rankupph?schema=public"

# Public site URL (used for SEO, OG, Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth.js / NextAuth (required) ────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_TRUST_HOST="true"

# Optional: seed admin credentials (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@rankupph.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Required for credential encryption. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# ── Google OAuth (optional) ──────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Stripe (optional — checkout disabled if blank) ───────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Pusher (optional — realtime falls back to polling/disabled)
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# ── Cloudinary (optional — chat/GCash image upload disabled if blank) ───
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# ── GCash payee shown to customers on the manual-payment screen ──
GCASH_NUMBER="0917 000 0000"
GCASH_NAME="RankUpPH"
