// ─────────────────────────────────────────────────────────────
// RankUpPH — Prisma schema
// Multi-game capable data model. MVP ships Dota 2 only (one Game row).
// Money is stored as integer centavos (PHP) to avoid float drift.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

// Top-level calculator categories. COACHING is retained in the model but
// hidden from the calculator tabs for now (added later).
enum ServiceCategory {
  MMR_BOOSTING
  CALIBRATION
  RANKED_WINS
  BATTLE_CUP
  LOW_PRIORITY
  COACHING
}

// How a service's base price is computed before options/modifiers apply.
enum PricingMethod {
  MMR_RANGE // banded per-100-MMR pricing across the current→target range
  PER_UNIT // unitPrice × quantity (wins, calibration matches, LP games)
  TIERED // sum of selected option price deltas (Battle Cup tier)
  SESSION // unitPrice × sessions (Coaching)
}

enum BoosterStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ModifierKind {
  MULTIPLIER // value is basis points (10000 = 1.0x)
  FLAT // value is centavos added
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  ASSIGNED
  IN_PROGRESS
  COMPLETED // booster marked done
  CONFIRMED // customer confirmed
  CLOSED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  GCASH
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REJECTED
}

enum NotificationType {
  PAYMENT_CONFIRMED
  BOOSTER_ASSIGNED
  PROGRESS_UPDATED
  ORDER_COMPLETED
  ORDER_CONFIRMED
  MESSAGE_RECEIVED
  GCASH_SUBMITTED
  GENERIC
}

enum VoucherType {
  PERCENT // value = whole percent (1–100)
  FIXED // value = centavos off
}

// ── Auth (NextAuth / Auth.js) ────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  emailVerified DateTime?
  passwordHash String?
  name         String?
  image        String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  boosterProfile BoosterProfile?

  ordersAsCustomer Order[]               @relation("CustomerOrders")
  ordersAsBooster  Order[]               @relation("BoosterOrders")
  chatParticipants ChatParticipant[]
  chatMessages     ChatMessage[]
  reviews          Review[]
  progressUpdates  OrderProgressUpdate[]
  notifications    Notification[]
  reviewedPayments Payment[]             @relation("PaymentReviewer")
  auditLogs        AuditLog[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Catalog ──────────────────────────────────────────────────

model Game {
  id       String  @id @default(cuid())
  slug     String  @unique
  name     String
  isActive Boolean @default(true)

  ranks            Rank[]
  services         Service[]
  pricingModifiers PricingModifier[]
  orders           Order[]

  createdAt DateTime @default(now())
}

model Rank {
  id          String  @id @default(cuid())
  gameId      String
  name        String
  order       Int // ascending: Herald=1 ... Immortal=8
  hasStars    Boolean @default(true)
  maxStar     Int     @default(5)
  iconUrl     String? // optional official medal image; falls back to SVG emblem
  // MMR band for this medal + its per-100-MMR boost rate (all DB-configurable).
  minMmr      Int     @default(0)
  maxMmr      Int     @default(0)
  pricePer100 Int     @default(0) // centavos per 100 MMR climbed within this band

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  ordersAsCurrent Order[] @relation("OrderCurrentRank")
  ordersAsTarget  Order[] @relation("OrderTargetRank")

  @@unique([gameId, order])
  @@index([gameId])
}

model Service {
  id               String          @id @default(cuid())
  gameId           String
  category         ServiceCategory
  pricingMethod    PricingMethod   @default(MMR_RANGE)
  slug             String          @unique
  title            String
  shortDescription String
  description      String          @db.Text
  deliveryEstimate String // human label, e.g. "1–3 days per rank"
  basePrice        Int // centavos — entry/min price shown on cards

  // PER_UNIT / SESSION configuration (centavos & bounds).
  unitPrice Int     @default(0)
  unitLabel String? // e.g. "win", "calibration match", "low-priority game"
  minUnits  Int     @default(1)
  maxUnits  Int     @default(100)

  imageUrl  String?
  features  String[] @default([])
  isActive  Boolean  @default(true)
  isVisible Boolean  @default(true) // shown in calculator tabs / listings
  sortOrder Int      @default(0)

  game    Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  options ServiceOption[]
  orders  Order[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId, category])
}

// Generic selectable option for a service (server, queue, Battle Cup tier,
// calibration skill level, region…). Drives both context-only selects and
// price-affecting selects — fully DB-configurable, never hardcoded.
model ServiceOption {
  id              String  @id @default(cuid())
  serviceId       String
  groupKey        String // "server" | "queue" | "tier" | "region" | "skill" | "completion"
  groupLabel      String // human label for the field, e.g. "Server"
  value           String // stable key, e.g. "sea"
  label           String // display, e.g. "SEA"
  description     String?
  priceDelta      Int     @default(0) // flat centavos added when selected
  priceMultiplier Int     @default(10000) // basis points; 10000 = ×1.0 (no change)
  isDefault       Boolean @default(false)
  sortOrder       Int     @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, groupKey])
}

model PricingModifier {
  id              String           @id @default(cuid())
  gameId          String
  key             String // DUO_QUEUE | PRIORITY | STREAM | OFFLINE ...
  label           String
  description     String?
  kind            ModifierKind
  value           Int // MULTIPLIER: basis points (13000 = +30%); FLAT: centavos
  serviceCategory ServiceCategory? // null = applies to all categories
  isBoostingMode  Boolean          @default(false) // rendered as Solo/Duo selector
  isActive        Boolean          @default(true)
  sortOrder       Int              @default(0)

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, key])
  @@index([gameId])
}

// ── Boosters ─────────────────────────────────────────────────

model BoosterProfile {
  id              String        @id @default(cuid())
  userId          String        @unique
  status          BoosterStatus @default(PENDING)
  displayName     String?
  bio             String?       @db.Text
  rankAchieved    String? // e.g. "Immortal 5000 MMR"
  rating          Float         @default(0)
  completedOrders Int           @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ── Orders ───────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique // human-readable e.g. RUP-7K3D9Q
  gameId        String
  serviceId     String
  customerId    String
  boosterId     String?
  status        OrderStatus @default(PENDING_PAYMENT)

  currentRankId String? // resolved from MMR for display/context
  currentStar   Int?
  targetRankId  String?
  targetStar    Int?
  currentMmr    Int?
  targetMmr     Int?

  // Category-specific inputs captured at order time.
  quantity      Int?        // PER_UNIT: wins / matches / LP games
  // Snapshot of chosen modifier keys, option selections, and computed breakdown.
  modifiers     Json        @default("[]")
  options       Json        @default("{}")
  breakdown     Json        @default("[]")
  estimatedDelivery String?
  subtotal      Int // centavos — pre-discount total
  amount        Int // centavos — authoritative charge (server-computed, post-discount)
  currency      String      @default("PHP")
  customerNotes String?     @db.Text
  voucherId     String?

  game     Game    @relation(fields: [gameId], references: [id])
  service  Service @relation(fields: [serviceId], references: [id])
  customer User    @relation("CustomerOrders", fields: [customerId], references: [id])
  booster  User?   @relation("BoosterOrders", fields: [boosterId], references: [id])

  currentRank Rank? @relation("OrderCurrentRank", fields: [currentRankId], references: [id])
  targetRank  Rank? @relation("OrderTargetRank", fields: [targetRankId], references: [id])
  voucher     Voucher? @relation(fields: [voucherId], references: [id])

  payments        Payment[]
  chat            OrderChat?
  credential      OrderCredential?
  review          Review?
  progressUpdates OrderProgressUpdate[]
  auditLogs       AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([boosterId])
  @@index([status])
}

model Payment {
  id                    String          @id @default(cuid())
  orderId               String
  provider              PaymentProvider
  status                PaymentStatus   @default(PENDING)
  amount                Int // centavos
  currency              String          @default("PHP")
  stripeSessionId       String?         @unique
  stripePaymentIntentId String?         @unique
  gcashReference        String?
  gcashScreenshotUrl    String?
  reviewedById          String?
  failureReason         String?

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("PaymentReviewer", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([provider, status])
}

// ── Chat ─────────────────────────────────────────────────────

enum ChatRole {
  CUSTOMER
  BOOSTER
  ADMIN
}

model OrderChat {
  id        String   @id @default(cuid())
  orderId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order        Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  participants ChatParticipant[]
  messages     ChatMessage[]
}

model ChatParticipant {
  id         String    @id @default(cuid())
  chatId     String
  userId     String
  role       ChatRole
  lastReadAt DateTime?

  chat OrderChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  chat        OrderChat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User                @relation(fields: [senderId], references: [id])
  attachments MessageAttachment[]

  @@index([chatId, createdAt])
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  url       String
  publicId  String?
  mimeType  String?
  width     Int?
  height    Int?
  bytes     Int?
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ── Account credentials (encrypted at rest) ──────────────────

enum SteamGuardStatus {
  NONE
  EMAIL
  MOBILE
  DISABLED
}

model OrderCredential {
  id               String           @id @default(cuid())
  orderId          String           @unique
  steamUsername    String
  steamPasswordEnc String           @db.Text // AES-256-GCM
  steamGuard       SteamGuardStatus @default(MOBILE)
  backupCodesEnc   String?          @db.Text // AES-256-GCM (codes, one per line)
  notes            String?          @db.Text
  submittedAt      DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ── Audit trail ──────────────────────────────────────────────

enum AuditAction {
  CREDENTIAL_VIEWED
  CREDENTIAL_UPDATED
  BACKUP_CODES_VIEWED
  BOOSTER_ASSIGNED
  ORDER_STARTED
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  orderId   String?
  ip        String?
  meta      Json?
  createdAt DateTime    @default(now())

  user  User?  @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
}

model Review {
  id          String   @id @default(cuid())
  orderId     String   @unique
  customerId  String
  serviceId   String
  boosterId   String? // retained for data; not surfaced publicly
  rating      Int // 1..5
  comment     String?  @db.Text
  tags        String[] @default([]) // "Fast Delivery", "Professional"…
  country     String? // ISO-3166 alpha-2, e.g. "PH" — rendered as flag
  isVerified  Boolean  @default(true) // verified order badge
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer User    @relation(fields: [customerId], references: [id])
  service  Service @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
}

model OrderProgressUpdate {
  id              String   @id @default(cuid())
  orderId         String
  boosterId       String
  note            String   @db.Text
  percentComplete Int      @default(0)
  createdAt       DateTime @default(now())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  booster User  @relation(fields: [boosterId], references: [id])

  @@index([orderId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(GENERIC)
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Voucher {
  id             String      @id @default(cuid())
  code           String      @unique // stored uppercase
  description    String?
  type           VoucherType
  value          Int // PERCENT: 1–100 ; FIXED: centavos
  active         Boolean     @default(true)
  minSubtotal    Int? // centavos — minimum order to qualify
  maxRedemptions Int? // null = unlimited (counts paid orders)
  firstOrderOnly Boolean     @default(false)
  expiresAt      DateTime?
  createdById    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  orders Order[]

  @@index([active])
}
